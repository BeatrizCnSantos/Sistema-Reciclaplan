<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER" prefWidth="400" prefHeight="350" xmlns:fx="http://javafx.com/fxml" fx:controller="AtendenteController">

    <Label text="NOVA COMPRA - BALANÇA" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER">
        <Label text="ID do Material:"/>
        <TextField fx:id="txtMaterialId" prefWidth="50"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Peso (KG):"/>
        <TextField fx:id="txtPeso" prefWidth="80"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Tara (KG):"/>
        <TextField fx:id="txtTara" prefWidth="80"/>
    </HBox>

    <Button text="Registrar Compra" onAction="#registrar" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Label fx:id="lblMensagem" text="" style="-fx-text-fill: blue;"/>
</VBox>